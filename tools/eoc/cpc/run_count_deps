#!/usr/bin/env bash
# Count trimmed EO dependency lines for supplied rule names on the default CPC input.
# Usage: run_count_deps RULE [RULE ...]
# Output: prints COUNT for one rule, or "RULE COUNT" for several rules.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

eoc_require_args "$0 RULE [RULE ...]" 1 "$#"

BUILD_DIR="$(eoc_build_dir)"
INPUT="$(eoc_cpc_input)"
FINAL_OUT_DIR="$(eoc_final_out_dir)"
TRIM_OUT="$FINAL_OUT_DIR/trim_defs/trim_gen.eo"
DID_BUILD=0

count_trim_lines() {
  awk '
    function paren_delta(s, i, c, d) {
      sub(/[[:space:]]*;.*/, "", s)
      d = 0
      for (i = 1; i <= length(s); ++i) {
        c = substr(s, i, 1)
        if (c == "(") {
          ++d
        } else if (c == ")") {
          --d
        }
      }
      return d
    }

    function is_uncounted_decl_cmd(line) {
      return \
        line ~ /^[[:space:]]*\(declare-const[[:space:]]/ || \
        line ~ /^[[:space:]]*\(declare-consts[[:space:]]/ || \
        line ~ /^[[:space:]]*\(declare-parameterized-const[[:space:]]/
    }

    /^[[:space:]]*$/ || /^[[:space:]]*;/ {
      next
    }

    skip_depth > 0 {
      skip_depth += paren_delta($0)
      if (skip_depth <= 0) {
        skip_depth = 0
      }
      next
    }

    is_uncounted_decl_cmd($0) {
      skip_depth = paren_delta($0)
      if (skip_depth < 0) {
        skip_depth = 0
      }
      next
    }

    {
      ++count
    }

    END {
      print count + 0
    }
  ' "$TRIM_OUT"
}

count_rule() {
  local rule="$1"
  local ARGS

  ARGS=(trim-defs --build-dir "$BUILD_DIR" --final-out-dir "$FINAL_OUT_DIR")
  if [[ "${EOC_NO_BUILD:-0}" != "0" || "$DID_BUILD" != "0" ]]; then
    ARGS+=(--no-build)
  fi
  ARGS+=("$INPUT" "$rule")

  eoc_run_driver "${ARGS[@]}" >/dev/null
  DID_BUILD=1
  count_trim_lines
}

if (( $# == 1 )); then
  count_rule "$1"
  exit 0
fi

for rule in "$@"; do
  count="$(count_rule "$rule")"
  printf '%s %s\n' "$rule" "$count"
done
