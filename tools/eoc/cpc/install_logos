#!/usr/bin/env bash
# Generate the full CPC Lean package and install it into local Logos trees.
# Usage: install_logos
# Output: reads generated Lean files from tools/eoc/out/lean/ and copies them
# to $LOGOS_DIR/Cpc and $TEST_DIR/Cpc, including per-rule files under
# Proofs/Rules/. Existing rule files are preserved in $LOGOS_DIR/Cpc. It then
# optionally regenerates example files from $LOGOS_TESTS_DIR when that
# directory exists.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

BUILD_DIR="$(eoc_build_dir)"
FINAL_OUT_DIR="$(eoc_final_out_dir)"
LOGOS_DIR="${LOGOS_DIR:-$HOME/logos}"
TEST_DIR="${TEST_DIR:-/local/ajreynol/lean/cpc}"
LOGOS_TESTS_DIR="${LOGOS_TESTS_DIR:-$HOME/ethos/smtlibTests/logos-tests}"
CVC5_LOGOS="${CVC5_LOGOS:-$HOME/bin/cvc5-logos}"
CPC_GEN_LOGOS_CMD="${CPC_GEN_LOGOS_CMD:-cpc_gen_logos.sh}"

echo "********* Generating Lean signature *********"
"$SCRIPT_DIR/run_gen_lean_all"

eoc_copy_lean_outputs "$LOGOS_DIR/Cpc" "$FINAL_OUT_DIR" 1
eoc_copy_lean_outputs "$TEST_DIR/Cpc" "$FINAL_OUT_DIR"

"$SCRIPT_DIR/install_logos_mini"

if [[ -d "$LOGOS_TESTS_DIR" ]]; then
  (
    cd "$LOGOS_TESTS_DIR"
    shopt -s nullglob
    for file in *.smt2; do
      base_file="$(basename "$file")"
      base_name="${base_file%.*}"
      echo "Generating $CVC5_LOGOS $PWD/$file to $LOGOS_DIR/examples/test-$base_name.cpc.lean"
      "$CPC_GEN_LOGOS_CMD" "$CVC5_LOGOS" "$file" > temp.lean
      mkdir -p "$LOGOS_DIR/examples" "$TEST_DIR/examples"
      cp temp.lean "$LOGOS_DIR/examples/test-$base_name.cpc.lean"
      cp temp.lean "$TEST_DIR/examples/test-$base_name.cpc.lean"
      rm -f temp.lean
    done
  )
fi
