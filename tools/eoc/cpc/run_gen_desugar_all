#!/usr/bin/env bash
# Generate a desugared EO file for the default CPC input or an explicit INPUT.
# Usage: run_gen_desugar_all [INPUT]
# Output: writes tools/eoc/out/desugar.eo.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

BUILD_DIR="$(eoc_build_dir)"
INPUT="${1:-$(eoc_cpc_input)}"
ARGS=(desugar --build-dir "$BUILD_DIR" "$INPUT")

eoc_add_no_build

eoc_exec_driver "${ARGS[@]}"
