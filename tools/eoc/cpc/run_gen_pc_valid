#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

eoc_require_args "$0 INPUT" 1 "$#"

BUILD_DIR="$(eoc_build_dir)"
ARGS=(pc-valid --build-dir "$BUILD_DIR")

eoc_add_no_build
eoc_add_skip_cvc5

ARGS+=("$1")
eoc_exec_driver "${ARGS[@]}"
