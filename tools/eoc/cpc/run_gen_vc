#!/usr/bin/env bash
# Generate SMT VCs for the supplied rule names on the default CPC input.
# Usage: run_gen_vc RULE [RULE ...]
# Output: writes stage EO files under tools/eoc/out/ and final SMT2 files under
# tools/eoc/out/vc/.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

BUILD_DIR="$(eoc_build_dir)"
INPUT="$(eoc_cpc_input)"
ARGS=(batch --build-dir "$BUILD_DIR" vc "$INPUT")

eoc_add_skip_cvc5

ARGS+=("$@")
eoc_exec_driver "${ARGS[@]}"
