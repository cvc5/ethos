#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

BUILD_DIR="$(eoc_build_dir)"
INPUT="${1:-$(eoc_alethe_input)}"
ARGS=(batch --build-dir "$BUILD_DIR" --clean vc "$INPUT" --all-rules)

eoc_add_no_build
eoc_add_skip_cvc5

eoc_exec_driver "${ARGS[@]}"
