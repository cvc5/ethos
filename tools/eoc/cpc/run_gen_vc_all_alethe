#!/usr/bin/env bash
# Generate SMT VCs for every discovered rule in the default or explicit Alethe INPUT.
# Usage: run_gen_vc_all_alethe [--solve] [--solve-args="ARGS"] [INPUT]
# Output: writes stage EO files under tools/eoc/out/ and final SMT2 files under
# tools/eoc/out/vc/.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

BUILD_DIR="$(eoc_build_dir)"
ARGS=(batch --build-dir "$BUILD_DIR" --clean vc "" --all-rules)

eoc_add_no_build
eoc_add_skip_cvc5
eoc_extract_solve_options "$@"

if (( ${#EOC_FILTERED_ARGS[@]} > 1 )); then
  echo "usage: $0 [--solve] [--solve-args=\"ARGS\"] [INPUT]" >&2
  exit 2
fi
INPUT="${EOC_FILTERED_ARGS[0]:-$(eoc_alethe_input)}"
ARGS[5]="$INPUT"

eoc_exec_driver "${ARGS[@]}"
