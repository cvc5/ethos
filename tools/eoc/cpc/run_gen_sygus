#!/usr/bin/env bash
# Generate one SyGuS query for RULE on the default CPC input.
# Usage: run_gen_sygus RULE
# Output: writes stage EO files under tools/eoc/out/ and, on success, a final
# query in tools/eoc/out/sygus/final-*.sy.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

eoc_require_args "$0 RULE" 1 "$#"

BUILD_DIR="$(eoc_build_dir)"
INPUT="$(eoc_cpc_input)"
ARGS=(vc --build-dir "$BUILD_DIR" --sygus "$INPUT" "$1")

eoc_add_skip_cvc5

eoc_exec_driver "${ARGS[@]}"
