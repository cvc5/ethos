#!/usr/bin/env bash
# Generate the reduced CPC Lean package used for CpcMini-style downstream tests.
# Usage: install_logos_mini
# Output: reads generated Lean files from tools/eoc/out/lean/ and copies them
# to $LOGOS_DIR/$SUB_DIR, including per-rule files under Proofs/Rules/. Any
# existing rule files are preserved, then imports are rewritten from Cpc.* to
# CpcMini.*.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

BUILD_DIR="$(eoc_build_dir)"
FINAL_OUT_DIR="$(eoc_final_out_dir)"
LOGOS_DIR="${LOGOS_DIR:-$HOME/logos}"
SUB_DIR="${SUB_DIR:-CpcMini}"
read -r -a MINI_TARGETS <<< "${MINI_TARGETS:-symm contra refl scope trans}"

echo "********* Generating Mini-Lean signature *********"
"$SCRIPT_DIR/run_gen_lean" "${MINI_TARGETS[@]}"

eoc_copy_lean_outputs "$LOGOS_DIR/$SUB_DIR" "$FINAL_OUT_DIR" 1

if [[ -d "$LOGOS_DIR/$SUB_DIR" ]]; then
  (
    cd "$LOGOS_DIR/$SUB_DIR"
    shopt -s nullglob
    for file in $(find -type f -name '*.lean'); do
      sed -i 's/import Cpc\./import CpcMini\./g' "$file"
      sed -i 's/partial def /def /g' "$file"
    done
  )
fi
