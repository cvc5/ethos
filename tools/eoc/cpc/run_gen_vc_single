#!/usr/bin/env bash
# Generate one VC for INPUT and RULE, or use -sygus to request a SyGuS query.
# Usage: run_gen_vc_single [-sygus] INPUT RULE
# Output: writes stage EO files under tools/eoc/out/ and a final file under
# tools/eoc/out/vc/ or tools/eoc/out/sygus/.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

eoc_require_args "$0 INPUT RULE" 2 "$#"

BUILD_DIR="$(eoc_build_dir)"
ARGS=(vc --build-dir "$BUILD_DIR")

eoc_add_no_build
eoc_add_skip_cvc5

if [[ "${1:-}" == "-sygus" ]]; then
  ARGS+=(--sygus)
  shift
  eoc_require_args "$0 [-sygus] INPUT RULE" 2 "$#"
fi

ARGS+=("$1" "$2")
eoc_exec_driver "${ARGS[@]}"
