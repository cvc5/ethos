#!/usr/bin/env bash
# Generate SyGuS queries for every discovered rule in the default or explicit INPUT.
# Usage: run_gen_sygus_all [INPUT]
# Output: writes stage EO files under tools/eoc/out/ and final queries under
# tools/eoc/out/sygus/.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

BUILD_DIR="$(eoc_build_dir)"
INPUT="${1:-$(eoc_cpc_input)}"
ARGS=(batch --build-dir "$BUILD_DIR" --clean sygus "$INPUT" --all-rules)

eoc_add_no_build
eoc_add_skip_cvc5

eoc_exec_driver "${ARGS[@]}"
