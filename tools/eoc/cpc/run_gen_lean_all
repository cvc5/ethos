#!/usr/bin/env bash
# Generate Lean output for every declaration in the default or explicit INPUT.
# Usage: run_gen_lean_all [INPUT]
# Output: writes stage EO files and final Lean files under tools/eoc/out/.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

BUILD_DIR="$(eoc_build_dir)"
INPUT="${1:-$(eoc_cpc_input)}"
ARGS=(lean --build-dir "$BUILD_DIR" --all)

eoc_add_no_build

ARGS+=("$INPUT")
eoc_exec_driver "${ARGS[@]}"
