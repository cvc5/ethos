#!/usr/bin/env bash
# Compatibility shim for the old script generator workflow.
# Usage: mkscripts INPUT
# Output: prints the discovered rule names to stdout and does not write files.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/common.sh"

echo "mkscripts is deprecated: batch wrappers now discover rules directly from the input signature." >&2
echo "Printing the discovered rule list instead." >&2

eoc_exec_driver list-rules "$@"
