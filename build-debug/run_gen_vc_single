#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BUILD_DIR="${BUILD_DIR:-$(pwd)}"
ARGS=(vc --build-dir "$BUILD_DIR")

if [[ "${EOC_NO_BUILD:-0}" != "0" ]]; then
  ARGS+=(--no-build)
fi

if [[ "${EOC_SKIP_CVC5:-0}" != "0" ]]; then
  ARGS+=(--skip-cvc5)
fi

if [[ "X$1" == "X-sygus" ]]; then
  ARGS+=(--sygus)
  shift
fi

ARGS+=("$1" "$2")
exec python3 "$SCRIPT_DIR/eoc_driver.py" "${ARGS[@]}"
