  ((s $smt_builtin_String) (d $smt_Datatype) (n $smt_builtin_Nat))
  :signature ($smt_builtin_String $smt_Datatype $smt_builtin_Nat) $smt_Value
  (
  (($smtx_model_eval_dt_cons s d n)
    
    ($smt_builtin_ite
      ($smt_builtin_Teq ($smtx_typeof_dt_cons_value s d n) $tsm_none)
