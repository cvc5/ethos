#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BUILD_DIR="${BUILD_DIR:-$(pwd)}"
INPUT="${1:-../../cvc5-ajr/proofs/eo/cpc/Cpc.eo}"
ARGS=(lean --build-dir "$BUILD_DIR" --all)

if [[ "${EOC_NO_BUILD:-0}" != "0" ]]; then
  ARGS+=(--no-build)
fi

ARGS+=("$INPUT")
exec python3 "$SCRIPT_DIR/eoc_driver.py" "${ARGS[@]}"
