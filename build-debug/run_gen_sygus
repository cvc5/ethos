#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BUILD_DIR="${BUILD_DIR:-$(pwd)}"
INPUT="../../cvc5-ajr/proofs/eo/cpc/Cpc.eo"

ARGS=(vc --build-dir "$BUILD_DIR" --sygus "$INPUT" "$1")
if [[ "${EOC_SKIP_CVC5:-0}" != "0" ]]; then
  ARGS+=(--skip-cvc5)
fi

exec python3 "$SCRIPT_DIR/eoc_driver.py" "${ARGS[@]}"
